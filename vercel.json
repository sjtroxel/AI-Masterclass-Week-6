{
  "comment": "Vercel deployment config — wired up and ready for Phase 8. Deployment itself does NOT happen until Phase 8.",
  "buildCommand": "npm ci && npm run build --workspace=client",
  "outputDirectory": "client/dist/client/browser",
  "framework": null,
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
