{
  "name": "asteroid-bonanza",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared",
    "scripts"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspace=client",
    "build": "npm run build --workspaces --if-present",
    "ingestNasa": "tsx --env-file=server/.env scripts/src/ingestNasa.ts",
    "generateEmbeddings": "tsx --env-file=server/.env scripts/src/generateEmbeddings.ts",
    "ingestDocuments": "tsx --env-file=server/.env scripts/src/ingestDocuments.ts",
    "validateRag": "tsx --env-file=server/.env scripts/src/validateRag.ts",
    "validateExternalApis": "tsx scripts/src/validateExternalApis.ts",
    "backfillCompositions": "tsx --env-file=server/.env scripts/src/backfillCompositions.ts",
    "deduplicateNasaIds": "tsx --env-file=server/.env scripts/src/deduplicateNasaIds.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "husky": "^9.1.7",
    "typescript": "^5.8.3"
  }
}
